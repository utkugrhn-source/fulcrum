# Frontend (Vite — exposed in client bundle)
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Backend (Vercel serverless — server-only, NEVER prefix with VITE_)
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# NCBI E-utilities (optional but recommended for higher rate limits)
# Get a key: https://www.ncbi.nlm.nih.gov/account/settings/
NCBI_API_KEY=
NCBI_TOOL=fulcrum
NCBI_EMAIL=utkugrhn@gmail.com

# Vercel Cron secret (set in Vercel Project Settings → Environment Variables)
CRON_SECRET=generate-a-random-32-char-string
